---
import Base from '../layouts/Base.astro'
import { useTranslations } from '../i18n/index'
import { getDirectusClient } from '../lib/directus'
import { readItems } from '@directus/sdk'

const t = useTranslations('de')

let page: { id: string; slug: string; title: string; content: string; status: 'published' | 'draft' } | undefined

try {
  const client = getDirectusClient()
  const pages = await client.request(
    readItems('pages', { filter: { slug: { _eq: 'ueber-uns' }, status: { _eq: 'published' } }, limit: 1 })
  )
  page = pages[0]
} catch {
  // Directus unavailable — show fallback
}
---

<Base title={t('about.heading')} lang="de">
  <section class="max-w-3xl mx-auto px-4 py-12">
    <h1 class="text-2xl sm:text-3xl font-bold text-navy mb-6">{t('about.heading')}</h1>
    {page ? (
      <div class="prose max-w-none" set:html={page.content} />
    ) : (
      <p class="text-gray-600">{t('pages.contentFallback')}</p>
    )}
  </section>
</Base>
